# ================================================================
# PaperIQ Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_STORAGE_BUCKET=papers

# LLM — automatic failover: groq → openrouter → ollama
LLM_PROVIDER_ORDER=groq,openrouter,ollama

# Groq (Priority 1) — free at console.groq.com
GROQ_API_KEY=
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_MEDIUM=qwen2.5-32b-preview
GROQ_MODEL_REASONING=deepseek-r1-distill-llama-70b

# OpenRouter (Priority 2) — free tier at openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL_FAST=qwen/qwen-2.5-7b-instruct:free
OPENROUTER_MODEL_MEDIUM=mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL_REASONING=deepseek/deepseek-r1:free

# Ollama (Priority 3) — local models
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_FAST=qwen2.5:7b
OLLAMA_MODEL_MEDIUM=qwen2.5:14b
OLLAMA_MODEL_REASONING=deepseek-r1:14b

# LLM failover tuning
LLM_FAILOVER_COOLDOWN_SECONDS=60
LLM_REQUEST_TIMEOUT_SECONDS=30

# Payments (stub — leave blank in MVP)
PAYMENT_PROVIDER=free
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# Application
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
API_VERSION=v1
LOG_LEVEL=INFO

# Scraper
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_DOWNLOAD_DIR=/tmp/paperiq_downloads
